<%- include('../partials/head') %>
<body class="bg-white flex flex-col min-h-screen">
  
  <%- include('../partials/nav') %>

  <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
    
    <!-- Title & Location Header -->
    <div class="mb-6">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">
        <%= home.houseName %>
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-800 mt-3 font-medium">
        <span class="flex items-center gap-1.5">
          <i class="fa-solid fa-star text-xs"></i> 
          <%= home.rating %>
        </span>
        <span class="underline decoration-gray-400 underline-offset-4 cursor-pointer">
          <%= home.location %>
        </span>
      </div>
    </div>

    <!-- Hero Image -->
    <div class="w-full h-[50vh] sm:h-[60vh] rounded-2xl overflow-hidden bg-gray-200 mb-10 shadow-sm border border-gray-100">
      <img 
        src="<%= home.photo %>" 
        alt="<%= home.houseName %>" 
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-700 ease-in-out"
      >
    </div>

    <!-- Layout Grid: Details on Left, Booking Card on Right -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      
      <!-- Left Column: Details -->
      <div class="lg:col-span-2 space-y-8">
        
        <div class="pb-8 border-b border-gray-200">
          <h2 class="text-2xl font-semibold text-gray-900 mb-4">About this space</h2>
          <p class="text-gray-600 leading-relaxed whitespace-pre-line text-lg">
            <%= home.description %>
          </p>
        </div>

        <div class="pb-8 border-b border-gray-200">
          <h2 class="text-2xl font-semibold text-gray-900 mb-4">What this place offers</h2>
          <ul class="grid grid-cols-2 gap-4 text-gray-600">
            <li class="flex items-center gap-3"><i class="fa-solid fa-wifi text-xl w-6"></i> Fast Wifi</li>
            <li class="flex items-center gap-3"><i class="fa-solid fa-tv text-xl w-6"></i> TV</li>
            <li class="flex items-center gap-3"><i class="fa-solid fa-kitchen-set text-xl w-6"></i> Kitchen</li>
            <li class="flex items-center gap-3"><i class="fa-solid fa-car text-xl w-6"></i> Free Parking</li>
          </ul>
        </div>

      </div>

      <!-- Right Column: Sticky Pricing Card -->
      <div class="lg:col-span-1">
        <div class="bg-white border border-gray-200 rounded-2xl shadow-xl p-6 sticky top-28">
          
          <div class="flex items-baseline gap-1 mb-6">
            <span class="text-3xl font-bold text-gray-900">₹<%= home.price %></span>
            <span class="text-gray-500 font-normal">/ night</span>
          </div>

          <!-- Favourite Partial Integration -->
          <div class="mt-4 w-full">
            <%- include('../partials/favourite') %>
          </div>

          <!-- Fake Reserve Button (Just for the premium look) -->
          <button class="w-full bg-rose-500 text-white font-semibold py-3.5 rounded-lg hover:bg-rose-600 transition-all duration-300 mt-3 text-lg shadow-md shadow-rose-500/20">
            Reserve
          </button>

          <div class="text-center mt-4 text-gray-500 text-sm">
            You won't be charged yet
          </div>
          
        </div>
      </div>

    </div>
  </main>

</body>
</html>