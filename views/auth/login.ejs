<%- include('../partials/head') %>

<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/nav') %>

  <main class="flex-grow flex items-center justify-center p-6">
    <div
      class="max-w-md w-full bg-white rounded-2xl shadow-xl border border-gray-100 p-8"
    >
      <div class="text-center mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900">Welcome back</h1>
        <p class="text-sm text-gray-500 mt-2">
          Log in to your account to continue
        </p>
      </div>

      <form action="/login" method="POST" class="space-y-5">
        <%- include('../partials/errors') %>

        <!-- Email Input -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >Email address</label
          >
          <input
            type="email"
            name="email"
            placeholder="you@example.com"
            value="<%= oldInput.email ? oldInput.email : '' %>"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-rose-500 transition-colors"
            required
          />
        </div>

        <!-- Password Input -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >Password</label
          >
          <input
            type="password"
            name="password"
            placeholder="••••••••"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-rose-500 transition-colors"
            required
          />
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full bg-rose-500 text-white font-semibold py-3 rounded-lg hover:bg-rose-600 transition-all duration-300 shadow-md shadow-rose-500/30 mt-4"
        >
          Sign In
        </button>
      </form>
    </div>
  </main>
</body>
