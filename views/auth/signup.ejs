<%- include('../partials/head') %>

<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/nav') %>

  <main class="flex-grow flex items-center justify-center p-6 py-12">
    <div class="max-w-lg w-full bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
      
      <div class="text-center mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900">Create an account</h1>
        <p class="text-sm text-gray-500 mt-2">Join us to start booking or hosting</p>
      </div>

      <form action="/signup" method="POST" class="space-y-5">
        <%- include('../partials/errors') %>

        <!-- Name Inputs (Side by Side) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
            <input
              type="text"
              name="firstName"
              placeholder="John"
              value="<%= oldInput.firstName ? oldInput.firstName : '' %>"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors"
              required
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
            <input
              type="text"
              name="lastName"
              placeholder="Doe"
              value="<%= oldInput.lastName ? oldInput.lastName : '' %>"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors"
            />
          </div>
        </div>

        <!-- Email Input -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email address</label>
          <input
            type="email"
            name="email"
            placeholder="you@example.com"
            value="<%= oldInput.email ? oldInput.email : '' %>"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors"
            required
          />
        </div>

        <!-- Password Inputs -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <input
            type="password"
            name="password"
            placeholder="Create a strong password"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors"
            required
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
          <input
            type="password"
            name="confirmPassword"
            placeholder="Repeat your password"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors"
            required
          />
        </div>

        <!-- User Type Selection -->
        <div class="pt-2">
          <p class="block text-sm font-medium text-gray-700 mb-3">How do you want to use Airbnb?</p>
          <div class="flex items-center gap-6">
            <label class="flex items-center cursor-pointer group">
              <input type="radio" name="userType" value="guest" id="guest" class="w-5 h-5 text-rose-500 border-gray-300 focus:ring-rose-500" checked="<%= oldInput.userType==="guest"%>" />
              <span class="ml-2 text-gray-700 group-hover:text-gray-900">I want to travel (Guest)</span>
            </label>
            <label class="flex items-center cursor-pointer group">
              <input type="radio" name="userType" value="host" id="host" class="w-5 h-5 text-rose-500 border-gray-300 focus:ring-rose-500" checked="<%= oldInput.userType==="host" %>" />
              <span class="ml-2 text-gray-700 group-hover:text-gray-900">I want to host</span>
            </label>
          </div>
        </div>

        <!-- Terms and Conditions -->
        <div class="pt-4 border-t border-gray-100">
          <label for="terms" class="flex items-start cursor-pointer">
            <input type="checkbox" name="terms" id="terms" class="mt-1 w-5 h-5 text-rose-500 rounded border-gray-300 focus:ring-rose-500" required />
            <span class="ml-3 text-sm text-gray-600">
              I agree to the <a href="#" class="text-rose-600 hover:underline">Terms of Service</a> and <a href="#" class="text-rose-600 hover:underline">Privacy Policy</a>.
            </span>
          </label>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full bg-rose-500 text-white font-semibold py-3 rounded-lg hover:bg-rose-600 transition-all duration-300 shadow-md shadow-rose-500/30 mt-2"
        >
          Create Account
        </button>

      </form>
    </div>
  </main>
</body>