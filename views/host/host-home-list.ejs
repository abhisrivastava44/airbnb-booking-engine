<%- include('../partials/head') %>
  <body>

<%- include('../partials/nav') %>
<main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-4xl">
  <h2 class="text-5xl text-gray-800 font-bold text-center mb-6">
    Hey Host: Here are your homes
  </h2>
<ul class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
  <% registeredHomes.forEach(Home => { %>
    <li class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition duration-300">
      
      <!-- Home Image -->
      <img 
        src="<%= Home.photo %>" 
        alt="<%= Home.houseName %>"
        class="w-full h-48 object-cover"
      />

      <!-- Card Body -->
      <div class="p-5">

        <!-- Name + Rating -->
        <div class="flex justify-between items-center mb-2">
          <h3 class="text-xl font-bold text-gray-800"><%= Home.houseName %></h3>
          <span class="flex items-center gap-1 bg-red-50 text-red-500 font-semibold text-sm px-3 py-1 rounded-full border border-red-200">
            ⭐ <%= Home.rating %>
          </span>
        </div>

        <!-- Location -->
        <p class="text-gray-500 text-sm mb-4">📍 <%= Home.location %></p>

        <!-- Price + Button -->


                <div class="flex justify-between items-center">
          <span class="text-red-500 font-bold text-lg">₹<%= Home.price %> <span class="text-gray-400 text-sm font-normal">/ night</span></span>
          <a href="/host/edit-home/<%=Home._id%>?editing=true" class="bg-red-500 text-white text-sm px-4 py-2 rounded-lg hover:bg-red-600 transition duration-300">
            Edit
          </a>
          <form action="/host/delete-home/<%= Home._id%>" method="POST">
              <button type="submit" class="bg-red-500 p-2">Delete</button>
          </form>
          
        </div>

      </div>
    </li>
  <% }) %>
</ul>
</main>
  </body>
</html>
