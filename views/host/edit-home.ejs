<%- include('../partials/head') %>
<body class="bg-gray-50 flex flex-col min-h-screen">

  <%- include('../partials/nav') %>

  <main class="flex-grow flex items-center justify-center p-6 py-12">
    <div class="max-w-2xl w-full bg-white rounded-2xl shadow-xl border border-gray-100 p-8 sm:p-10">
      
      <div class="text-center mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900">
          <%= editing ? "Update Property Details" : "List Your Home" %>
        </h1>
        <p class="text-sm text-gray-500 mt-2">Fill in the details below to showcase your space.</p>
      </div>

      <form action="/host/<%= editing ? 'edit-home' : 'add-home' %>" method="POST" class="space-y-6" enctype="multipart/form-data">
        
        <!-- Hidden ID for Editing -->
        <input name="id" value="<%= editing ? home._id : '' %>" type="hidden">
        
        <!-- House Name -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Property Title</label>
          <input
            type="text"
            name="houseName"
            value="<%= editing ? home.houseName : '' %>"
            placeholder="e.g. Cozy Cabin in the Woods"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors"
            required
          />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <!-- Price -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Price per night (₹)</label>
            <input
              type="number"
              name="price"
              value="<%= editing ? home.price : '' %>"
              placeholder="0.00"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors"
              required
            />
          </div>

          <!-- Rating -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Initial Rating (1-5)</label>
            <input
              type="number"
              step="0.1"
              max="5"
              min="0"
              name="rating"
              value="<%= editing ? home.rating : '' %>"
              placeholder="e.g. 4.5"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors"
              required
            />
          </div>
        </div>

        <!-- Location -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Location / Address</label>
          <input
            type="text"
            name="location"
            value="<%= editing ? home.location : '' %>"
            placeholder="e.g. Mumbai, Maharashtra"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors"
            required
          />
        </div>

        <!-- Photo Upload -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Property Photo</label>
          <input
            type="file"
            name="photo"
            accept="image/jpg, image/jpeg, image/png"
            class="w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-rose-50 file:text-rose-600 hover:file:bg-rose-100 cursor-pointer border border-gray-300 rounded-lg p-1"
            <%= editing ? '' : 'required' %>
          />
        </div>

        <!-- Description -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea
            name="description"
            rows="4"
            placeholder="Tell guests what makes your place special..."
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 transition-colors resize-none"
            required
          ><%= editing ? home.description : '' %></textarea>
        </div>

        <!-- Submit Button -->
        <button 
          type="submit" 
          class="w-full bg-rose-500 text-white font-semibold py-3.5 rounded-lg hover:bg-rose-600 transition-all duration-300 shadow-md shadow-rose-500/30 mt-4 text-lg"
        >
          <%= editing ? "Update Property" : "Publish Listing" %>
        </button>

      </form>
    </div>
  </main>

</body>