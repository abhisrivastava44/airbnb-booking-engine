<!-- Modern Sticky Navbar -->
<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex justify-between items-center">
    
    <!-- Logo -->
    <div class="flex-shrink-0 flex items-center">
      <a href="/" class="text-rose-500 text-3xl font-bold flex items-center gap-2 hover:opacity-90 transition-opacity">
        <i class="fa-brands fa-airbnb"></i> airbnb
      </a>
    </div>

    <!-- Nav Links -->
    <div class="hidden md:flex space-x-2 items-center text-sm font-medium">
      
      <% if(isLoggedIn) { %>
        <!-- Guest & Host Shared Links -->
        <a href="/homes" class="<%= currentPage === 'homes' ? 'text-gray-900 bg-gray-100' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900' %> px-4 py-2 rounded-full transition-all duration-300">
          Homes
        </a>
        <a href="/favourites" class="<%= currentPage === 'favourites' ? 'text-gray-900 bg-gray-100' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900' %> px-4 py-2 rounded-full transition-all duration-300">
          Favourites
        </a>
        <a href="/bookings" class="<%= currentPage === 'bookings' ? 'text-gray-900 bg-gray-100' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900' %> px-4 py-2 rounded-full transition-all duration-300">
          Bookings
        </a>

        <!-- Host Specific Options -->
        <% if(user && user.userType === 'host'){ %>
          <div class="h-6 w-px bg-gray-300 mx-2"></div> <!-- Visual Divider -->
          <a href="/host/host-home-list" class="<%= currentPage === 'host-homes' ? 'text-rose-500 bg-rose-50' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900' %> px-4 py-2 rounded-full transition-all duration-300">
            My Properties
          </a>
          <a href="/host/add-home" class="<%= currentPage === 'addHome' ? 'text-rose-500 bg-rose-50' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900' %> px-4 py-2 rounded-full transition-all duration-300">
            Add Home
          </a>
        <% } %>

        <!-- Logout Button -->
        <form action="/logout" method="POST" class="ml-4 pl-4 border-l border-gray-200">
          <button type="submit" class="bg-gray-900 hover:bg-gray-800 text-white py-2 px-6 rounded-full transition duration-300">
            Logout
          </button>
        </form>

      <% } else { %>
        <!-- Logged Out Links -->
        <a href="/signup" class="<%= currentPage === 'signup' ? 'text-gray-900 bg-gray-100' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900' %> px-5 py-2 rounded-full transition-all duration-300">
          Sign Up
        </a>
        <a href="/login" class="bg-rose-500 hover:bg-rose-600 text-white py-2 px-6 rounded-full transition duration-300 shadow-md shadow-rose-500/20">
          Log In
        </a>
      <% } %>
      
    </div>
  </nav>
</header>